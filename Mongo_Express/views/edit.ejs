<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editing Chat</title>
</head>
<body>
    <p>Edit your chat: <%=Curr_chat._id%></p>
    <p>This chat was sent from <b><%=Curr_chat.from%></b> to <b><%=Curr_chat.to%></b></p>
    <form method="POST" action="/chats/<%=Curr_chat._id%>?_method=PUT">
        <textarea name="msg" rows="6" cols="50" id=""><%=Curr_chat.msg%></textarea>
        <br>
        <button>Edit</button>
    </form>
</body>
</html>